<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebDevSecOps</title>
    <script type="importmap" nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/toastr/toastr.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebDevSecOps.styles.css" asp-append-version="true" />
    <style nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])">
        body { font-family: 'Roboto', sans-serif; }
    </style>
</head>
<body>
    <div class="wrapper">
        <aside id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" asp-area="" asp-page="/Index">
                    <i class="fas fa-shield-halved"></i>
                    <span class="sidebar-text">WebDevSecOps</span>
                </a>
            </div>
            <ul class="sidebar-nav">
                <li>
                    <a asp-area="" asp-page="/Index">
                        <i class="fas fa-home"></i>
                        <span class="sidebar-text">Home</span>
                    </a>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="sidebar-divider"><span>Administración</span></li>
                    <li>
                        <a href="/Usuario/Index">
                            <i class="fas fa-users"></i>
                            <span class="sidebar-text">Usuarios</span>
                        </a>
                    </li>
                    <li>
                        <a href="/Empleado/Index">
                            <i class="fas fa-user-tie"></i>
                            <span class="sidebar-text">Empleados</span>
                        </a>
                    </li>
                    <li>
                        <a href="/Cliente/Index">
                            <i class="fas fa-handshake"></i>
                            <span class="sidebar-text">Clientes</span>
                        </a>
                    </li>
                    <li>
                        <a href="/Producto/Index">
                            <i class="fas fa-box"></i>
                            <span class="sidebar-text">Productos</span>
                        </a>
                    </li>
                    <li>
                        <a href="/Venta/Index">
                            <i class="fas fa-cart-shopping"></i>
                            <span class="sidebar-text">Ventas</span>
                        </a>
                    </li>
                }
            </ul>
        </aside>

        <div class="main-content">
            <nav class="top-navbar">
                <div class="d-flex align-items-center">
                    @if (ViewData["HideMenu"] is not true)
                    {
                        <button id="sidebarToggle" class="btn btn-link top-navbar-btn" type="button" aria-label="Toggle sidebar">
                            <i class="fas fa-bars"></i>
                        </button>
                    }
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small d-none d-md-inline">
                            <i class="fas fa-user me-1"></i>@User.Identity.Name
                        </span>
                        <a class="btn btn-outline-danger btn-sm" asp-page="/Index" asp-page-handler="Logout">
                            <i class="fas fa-right-from-bracket"></i>
                            <span class="d-none d-md-inline ms-1">Cerrar</span>
                        </a>
                    </div>
                }
            </nav>

            <main class="content">
                <div id="mainContent">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js" nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])"></script>
    <script src="~/lib/toastr/toastr.min.js" nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])"></script>
    <script src="~/js/site.js" asp-append-version="true" nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])"></script>

    <script nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])">
        toastr.options = {
            "closeButton": true,
            "debug": false,
            "newestOnTop": false,
            "progressBar": true,
            "positionClass": "toast-bottom-right",
            "preventDuplicates": false,
            "onclick": null,
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideMethod": "fadeOut"
        };

        @if (TempData["Success"] is not null)
        {
            @:toastr["success"]("Operación exitosa!!");
        }
        @if (TempData["Error"] is not null)
        {
            @:toastr["error"]("Error al procesar la operación");
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>