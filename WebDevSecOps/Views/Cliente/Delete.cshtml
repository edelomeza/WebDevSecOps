@model ClienteDeleteViewModel
@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="mb-4">Eliminar Cliente</h2>

            @{
                var generalErrors = ViewData.ModelState[string.Empty]?.Errors;
            }
            @if (generalErrors is { Count: > 0 })
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @foreach (var error in generalErrors)
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="alert alert-warning">
                <strong>Advertencia:</strong> Esta accion no se puede deshacer. Confirme que desea eliminar este cliente.
            </div>

            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <input asp-for="Id" type="hidden" />
                <input asp-for="RowVersion" type="hidden" />

                <div class="card">
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrNombreCliente)</dt>
                            <dd class="col-sm-8">@Model.StrNombreCliente</dd>

                            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrDireccionCliente)</dt>
                            <dd class="col-sm-8">@(Model.StrDireccionCliente ?? "-")</dd>

                            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrCorreoElectronico)</dt>
                            <dd class="col-sm-8">@Model.StrCorreoElectronico</dd>

                            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrNumeroTelefono)</dt>
                            <dd class="col-sm-8">@Model.StrNumeroTelefono</dd>
                        </dl>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                    <a href="@(ViewData["ReturnUrl"] ?? Url.Action("Index"))" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
