@model ClienteDetailsViewModel
@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card card-table">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-handshake me-2 text-success"></i>Detalles del Cliente</h4>
                </div>
                <div class="card-body">
                    @{
                        var generalErrors = ViewData.ModelState[string.Empty]?.Errors;
                    }
                    @if (generalErrors is { Count: > 0 })
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @foreach (var error in generalErrors)
                            {
                                <p class="mb-0">@error.ErrorMessage</p>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <dl class="row mb-0">
                        <dt class="col-sm-4"><i class="fas fa-user me-1 text-muted"></i> @Html.DisplayNameFor(m => m.StrNombreCliente)</dt>
                        <dd class="col-sm-8">@Model.StrNombreCliente</dd>

                        <dt class="col-sm-4"><i class="fas fa-map-marker-alt me-1 text-muted"></i> @Html.DisplayNameFor(m => m.StrDireccionCliente)</dt>
                        <dd class="col-sm-8">@(Model.StrDireccionCliente ?? "-")</dd>

                        <dt class="col-sm-4"><i class="fas fa-envelope me-1 text-muted"></i> @Html.DisplayNameFor(m => m.StrCorreoElectronico)</dt>
                        <dd class="col-sm-8">@Model.StrCorreoElectronico</dd>

                        <dt class="col-sm-4"><i class="fas fa-phone me-1 text-muted"></i> @Html.DisplayNameFor(m => m.StrNumeroTelefono)</dt>
                        <dd class="col-sm-8">@Model.StrNumeroTelefono</dd>
                    </dl>
                </div>
                <div class="card-footer d-flex justify-content-end gap-2">
                    <a href="@(ViewData["ReturnUrl"] ?? Url.Action("Index"))" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Regresar
                    </a>
                    <a class="btn btn-outline-success" asp-action="Update" asp-route-id="@Model.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
                        <i class="fas fa-pen-to-square me-1"></i>Editar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
