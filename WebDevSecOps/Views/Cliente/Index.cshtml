@model PaginatedResponse<Cliente>
@{
    ViewData["Title"] = "Clientes";
    var currentQuery = Context.Request.Query;
    var texto = currentQuery["texto"].FirstOrDefault();
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Clientes</h2>
        <a class="btn btn-primary" asp-action="Create" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">+ Agregar Cliente</a>
    </div>

    <form method="get" action="/Cliente/Index" class="row g-3 mb-4">
        <div class="col-md-4">
            <input type="text" name="texto" class="form-control" placeholder="Buscar por nombre..." value="@texto" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Buscar</button>
        </div>
        <div class="col-md-2">
            <a href="/Cliente/Index" class="btn btn-outline-secondary w-100">Limpiar</a>
        </div>
    </form>

    @if (Model?.Items is null || Model.Items.Count == 0)
    {
        <div class="alert alert-info">No se encontraron clientes.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Nombre</th>
                        <th scope="col">Direccion</th>
                        <th scope="col">Correo Electronico</th>
                        <th scope="col">Telefono</th>
                        <th scope="col">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cliente in Model.Items)
                    {
                        <tr>
                            <td>@cliente.StrNombreCliente</td>
                            <td>@(cliente.StrDireccionCliente ?? "-")</td>
                            <td>@cliente.StrCorreoElectronico</td>
                            <td>@cliente.StrNumeroTelefono</td>
                            <td>
                                <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@cliente.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">Detalles</a>
                                <a class="btn btn-sm btn-warning" asp-action="Update" asp-route-id="@cliente.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">Actualizar</a>
                                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@cliente.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Navegacion de clientes">
            <ul class="pagination justify-content-center">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="/Cliente/Index?texto=@texto&pageNumber=@(Model.PageNumber - 1)&pageSize=@Model.PageSize">Anterior</a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link">Anterior</span>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="/Cliente/Index?texto=@texto&pageNumber=@i&pageSize=@Model.PageSize">@i</a>
                    </li>
                }

                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="/Cliente/Index?texto=@texto&pageNumber=@(Model.PageNumber + 1)&pageSize=@Model.PageSize">Siguiente</a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link">Siguiente</span>
                    </li>
                }
            </ul>
        </nav>

        <p class="text-center text-muted small">
            Mostrando pagina @Model.PageNumber de @Model.TotalPages (@Model.TotalCount registros)
        </p>
    }
</div>
