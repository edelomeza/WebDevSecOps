@model ClienteUpdateViewModel
@{
    ViewData["Title"] = "Actualizar Cliente";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card card-table">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-handshake me-2 text-success"></i>Actualizar Cliente</h4>
                </div>
                <div class="card-body">
                    @{
                        var generalErrors = ViewData.ModelState[string.Empty]?.Errors;
                    }
                    @if (generalErrors is { Count: > 0 })
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @foreach (var error in generalErrors)
                            {
                                <p class="mb-0">@error.ErrorMessage</p>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <input asp-for="Id" type="hidden" />
                        <input asp-for="RowVersion" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="StrNombreCliente" class="form-label"><i class="fas fa-user me-1 text-muted"></i> @Html.DisplayNameFor(m => m.StrNombreCliente)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fas fa-user text-muted"></i></span>
                                <input asp-for="StrNombreCliente" class="form-control" autocomplete="off" />
                            </div>
                            <span asp-validation-for="StrNombreCliente" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StrDireccionCliente" class="form-label"><i class="fas fa-map-marker-alt me-1 text-muted"></i> @Html.DisplayNameFor(m => m.StrDireccionCliente)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fas fa-map-marker-alt text-muted"></i></span>
                                <input asp-for="StrDireccionCliente" class="form-control" autocomplete="off" />
                            </div>
                            <span asp-validation-for="StrDireccionCliente" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StrCorreoElectronico" class="form-label"><i class="fas fa-envelope me-1 text-muted"></i> @Html.DisplayNameFor(m => m.StrCorreoElectronico)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fas fa-envelope text-muted"></i></span>
                                <input asp-for="StrCorreoElectronico" class="form-control" autocomplete="off" type="email" />
                            </div>
                            <span asp-validation-for="StrCorreoElectronico" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StrNumeroTelefono" class="form-label"><i class="fas fa-phone me-1 text-muted"></i> @Html.DisplayNameFor(m => m.StrNumeroTelefono)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fas fa-phone text-muted"></i></span>
                                <input asp-for="StrNumeroTelefono" class="form-control" autocomplete="off" maxlength="10" type="tel" />
                            </div>
                            <span asp-validation-for="StrNumeroTelefono" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a href="@(ViewData["ReturnUrl"] ?? Url.Action("Index"))" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-1"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-outline-success">
                                <i class="fas fa-save me-1"></i>Guardar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])">
        (function () {
            var form = document.querySelector('form.needs-validation');
            if (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                });
            }
        })();
    </script>
}
