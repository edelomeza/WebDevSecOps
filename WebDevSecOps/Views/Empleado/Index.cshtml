@model PaginatedResponse<Empleado>
@{
    ViewData["Title"] = "Empleados";
    var currentQuery = Context.Request.Query;
    var texto = currentQuery["texto"].FirstOrDefault();
    var idTipoEmpleado = currentQuery["idTipoEmpleado"].FirstOrDefault();
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="fas fa-user-tie me-2 text-success"></i>Empleados</h2>
        <a class="btn btn-outline-success" asp-action="Create" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
            <i class="fas fa-plus me-1"></i>Agregar Empleado
        </a>
    </div>

    <form method="get" action="/Empleado/Index" class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                <input type="text" name="texto" class="form-control" placeholder="Buscar por nombre..." value="@texto" />
            </div>
        </div>
        <div class="col-md-3">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="fas fa-user-tag text-muted"></i></span>
                <select name="idTipoEmpleado" class="form-select">
                    <option value="">Todos los tipos</option>
                    @if (ViewBag.TipoEmpleadoList is not null)
                    {
                        foreach (var item in ViewBag.TipoEmpleadoList)
                        {
                            <option value="@item.Value" selected="@(item.Value == idTipoEmpleado)">@item.Text</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-success w-100"><i class="fas fa-search me-1"></i>Buscar</button>
        </div>
        <div class="col-md-2">
            <a href="/Empleado/Index" class="btn btn-outline-secondary w-100"><i class="fas fa-eraser me-1"></i>Limpiar</a>
        </div>
    </form>

    @if (Model?.Items is null || Model.Items.Count == 0)
    {
        <div class="alert alert-info"><i class="fas fa-info-circle me-1"></i>No se encontraron empleados.</div>
    }
    else
    {
        <div class="card card-table">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-list me-2 text-success"></i>Listado de Empleados</span>
                <span class="badge bg-success">@Model.TotalCount registros</span>
            </div>
            <div class="card-body p-0">
                <div id="skeleton-Empleado">
                    <div class="skeleton-table-wrapper">
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                    </div>
                </div>
                <div id="table-Empleado" class="d-none">
                    <div class="table-responsive">
                        <table class="table-jtable">
                            <thead>
                                <tr>
                                    <th scope="col">Nombre</th>
                                    <th scope="col">A. Paterno</th>
                                    <th scope="col">A. Materno</th>
                                    <th scope="col">CURP</th>
                                    <th scope="col">Tipo Empleado</th>
                                    <th scope="col" class="text-center" style="width:130px">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var empleado in Model.Items)
                                {
                                    <tr>
                                        <td>@empleado.StrNombre</td>
                                        <td>@empleado.StrAPaterno</td>
                                        <td>@empleado.StrAMaterno</td>
                                        <td>@empleado.StrCURP</td>
                                        @{
                                            var tipoValor = "-";
                                            if (empleado.IdEmpCatTipoEmpleado.HasValue)
                                            {
                                                var idTipo = empleado.IdEmpCatTipoEmpleado.GetValueOrDefault();
                                                if (ViewBag.TipoEmpleadoDict.ContainsKey(idTipo))
                                                {
                                                    tipoValor = ViewBag.TipoEmpleadoDict[idTipo];
                                                }
                                            }
                                        }
                                        <td>@tipoValor</td>
                                        <td class="text-center">
                                            <a class="btn btn-sm btn-icon btn-outline-info" asp-action="Details" asp-route-id="@empleado.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a class="btn btn-sm btn-icon btn-outline-warning" asp-action="Update" asp-route-id="@empleado.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" title="Actualizar">
                                                <i class="fas fa-pen-to-square"></i>
                                            </a>
                                            <a class="btn btn-sm btn-icon btn-outline-danger" asp-action="Delete" asp-route-id="@empleado.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" title="Eliminar">
                                                <i class="fas fa-trash-can"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <small class="text-muted">Mostrando página @Model.PageNumber de @Model.TotalPages</small>
                <nav aria-label="Navegacion de empleados">
                    <ul class="pagination pagination-jtable mb-0">
                        @if (Model.PageNumber > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="/Empleado/Index?texto=@texto&idTipoEmpleado=@idTipoEmpleado&pageNumber=@(Model.PageNumber - 1)&pageSize=@Model.PageSize" title="Anterior">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="fas fa-chevron-left"></i></span>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="/Empleado/Index?texto=@texto&idTipoEmpleado=@idTipoEmpleado&pageNumber=@i&pageSize=@Model.PageSize">@i</a>
                            </li>
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="/Empleado/Index?texto=@texto&idTipoEmpleado=@idTipoEmpleado&pageNumber=@(Model.PageNumber + 1)&pageSize=@Model.PageSize" title="Siguiente">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="fas fa-chevron-right"></i></span>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>
