@model ProductoDeleteViewModel
@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="mb-4">Eliminar Producto</h2>

            <div class="alert alert-warning" role="alert">
                <i class="bi bi-exclamation-triangle"></i>
                Esta accion no se puede deshacer. Confirme que desea eliminar permanentemente este producto.
            </div>

            @{
                var generalErrors = ViewData.ModelState[string.Empty]?.Errors;
            }
            @if (generalErrors is { Count: > 0 })
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @foreach (var error in generalErrors)
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <input asp-for="Id" type="hidden" />
                <input asp-for="RowVersion" type="hidden" />

                <dl class="row mb-4">
                    <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrNombreProducto)</dt>
                    <dd class="col-sm-8">@Model.StrNombreProducto</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrDescripcion)</dt>
                    <dd class="col-sm-8">@(Model.StrDescripcion ?? "-")</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(m => m.IntNumeroExistencia)</dt>
                    <dd class="col-sm-8">@Model.IntNumeroExistencia</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(m => m.DecPrecio)</dt>
                    <dd class="col-sm-8">@Model.DecPrecio.ToString("C")</dd>
                </dl>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Confirmar Eliminar</button>
                    <a href="@(ViewData["ReturnUrl"] ?? Url.Action("Index"))" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
