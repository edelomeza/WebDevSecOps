@model ProductoDetailsViewModel
@{
    ViewData["Title"] = "Detalles del Producto";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="mb-4">Detalles del Producto</h2>

            @{
                var generalErrors = ViewData.ModelState[string.Empty]?.Errors;
            }
            @if (generalErrors is { Count: > 0 })
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @foreach (var error in generalErrors)
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrNombreProducto)</dt>
                        <dd class="col-sm-8">@Model.StrNombreProducto</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrURLImagen)</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.StrURLImagen))
                            {
                                <a href="@Model.StrURLImagen" target="_blank" rel="noopener noreferrer">@Model.StrURLImagen</a>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.StrDescripcion)</dt>
                        <dd class="col-sm-8">@(Model.StrDescripcion ?? "-")</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.IntNumeroExistencia)</dt>
                        <dd class="col-sm-8">@Model.IntNumeroExistencia</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.DecPrecio)</dt>
                        <dd class="col-sm-8">@Model.DecPrecio.ToString("C")</dd>
                    </dl>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <a class="btn btn-primary" asp-action="Update"
                   asp-route-id="@Model.Id"
                   asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">Editar</a>
                <a href="@(ViewData["ReturnUrl"] ?? Url.Action("Index"))" class="btn btn-secondary">Regresar</a>
            </div>
        </div>
    </div>
</div>
