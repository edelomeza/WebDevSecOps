@model PaginatedResponse<Usuario>
@{
    ViewData["Title"] = "Usuarios";
    var searchString = ViewData["SearchString"] as string;
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="fas fa-users me-2 text-success"></i>Usuarios</h2>
        <a class="btn btn-outline-success" asp-action="Create" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
            <i class="fas fa-plus me-1"></i>Agregar Usuario
        </a>
    </div>

    <form method="get" class="row g-2 mb-4" role="search">
        <div class="col-auto flex-grow-1">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                <input type="search"
                       class="form-control"
                       name="searchString"
                       id="searchString"
                       value="@searchString"
                       placeholder="Buscar por nombre..."
                       aria-label="Buscar por nombre"
                       maxlength="100">
                <button type="submit" class="btn btn-outline-success">
                    <i class="fas fa-search me-1"></i>Buscar
                </button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(searchString))
        {
            <div class="col-auto">
                <a class="btn btn-outline-secondary" asp-action="Index"><i class="fas fa-eraser me-1"></i>Limpiar</a>
            </div>
        }
    </form>

    @if (!string.IsNullOrEmpty(searchString))
    {
        <div class="alert alert-info py-2 mb-3">
            <i class="fas fa-filter me-1"></i><strong>Filtrado por:</strong> "@searchString"
        </div>
    }

    @if (Model?.Items is null || Model.Items.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-1"></i>
            @if (!string.IsNullOrEmpty(searchString))
            {
                <text>No se encontraron usuarios que coincidan con "@searchString".</text>
            }
            else
            {
                <text>No se encontraron usuarios.</text>
            }
        </div>
    }
    else
    {
        <div class="card card-table">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-list me-2 text-success"></i>Listado de Usuarios</span>
                <span class="badge bg-success">@Model.TotalCount registros</span>
            </div>
            <div class="card-body p-0">
                <div id="skeleton-Usuario">
                    <div class="skeleton-table-wrapper">
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                    </div>
                </div>
                <div id="table-Usuario" class="d-none">
                    <div class="table-responsive">
                        <table class="table-jtable">
                            <thead>
                                <tr>
                                    <th scope="col">Nombre</th>
                                    <th scope="col">Correo Electrónico</th>
                                    <th scope="col" class="text-center" style="width:130px">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var usuario in Model.Items)
                                {
                                    <tr>
                                        <td>@usuario.StrNombre</td>
                                        <td>@usuario.StrCorreoElectronico</td>
                                        <td class="text-center">
                                            <a class="btn btn-sm btn-icon btn-outline-info" asp-action="Details" asp-route-id="@usuario.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a class="btn btn-sm btn-icon btn-outline-warning" asp-action="Update" asp-route-id="@usuario.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" title="Actualizar">
                                                <i class="fas fa-pen-to-square"></i>
                                            </a>
                                            <a class="btn btn-sm btn-icon btn-outline-danger" asp-action="Delete" asp-route-id="@usuario.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" title="Eliminar">
                                                <i class="fas fa-trash-can"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <small class="text-muted">Mostrando página @Model.PageNumber de @Model.TotalPages</small>
                <nav aria-label="Navegación de usuarios">
                    <ul class="pagination pagination-jtable mb-0">
                        @if (Model.PageNumber > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="/Usuario/Index?searchString=@(searchString)&amp;pageNumber=@(Model.PageNumber - 1)&amp;pageSize=@Model.PageSize" title="Anterior">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="fas fa-chevron-left"></i></span>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="/Usuario/Index?searchString=@(searchString)&amp;pageNumber=@i&amp;pageSize=@Model.PageSize">@i</a>
                            </li>
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="/Usuario/Index?searchString=@(searchString)&amp;pageNumber=@(Model.PageNumber + 1)&amp;pageSize=@Model.PageSize" title="Siguiente">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="fas fa-chevron-right"></i></span>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>
