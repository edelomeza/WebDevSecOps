@model VentaProductosViewModel
@{
    ViewData["Title"] = "Productos de Venta: " + Model.StrClaveVenta;
    var estadoDict = ViewBag.EstadoVentaDict as Dictionary<int, string> ?? [];
}

<div class="container">
    <h2 class="mb-4"><i class="fas fa-box-open me-2 text-success"></i>Productos de Venta: @Model.StrClaveVenta</h2>

    @* ===== Seccion 1: Datos de la Venta (solo lectura) ===== *@
    <div class="card card-table mb-4">
        <div class="card-header"><h5 class="mb-0"><i class="fas fa-info-circle me-2 text-success"></i>Datos de la Venta</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">@Html.DisplayNameFor(m => m.DteFechaHoraCompra)</label>
                    <p class="form-control-plaintext">@Model.DteFechaHoraCompra?.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">@Html.DisplayNameFor(m => m.StrClaveVenta)</label>
                    <p class="form-control-plaintext">@Model.StrClaveVenta</p>
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">@Html.DisplayNameFor(m => m.StrNombreCliente)</label>
                    <p class="form-control-plaintext">@Model.StrNombreCliente</p>
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">@Html.DisplayNameFor(m => m.StrNombreUsuario)</label>
                    <p class="form-control-plaintext">@Model.StrNombreUsuario</p>
                </div>
            </div>
        </div>
    </div>

    @* ===== Seccion 2: Estado + Agregar Producto ===== *@
    <div class="card card-table mb-4">
        <div class="card-header"><h5 class="mb-0"><i class="fas fa-cogs me-2 text-success"></i>Estado y Productos</h5></div>
        <div class="card-body">
            <div class="row align-items-end mb-3">
                <div class="col-md-4">
                    <label for="idVenCatEstado" class="form-label"><i class="fas fa-tag me-1 text-muted"></i>Estado de Venta</label>
                    <select id="idVenCatEstado" class="form-select">
                        @foreach (var estado in estadoDict)
                        {
                            <option value="@estado.Key" selected="@(estado.Key == Model.IdVenCatEstado)">@estado.Value</option>
                        }
                    </select>
                </div>
            </div>

            <hr />

            <form method="post" action="/Venta/AgregarProducto" class="row g-3" id="agregarProductoForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="IdVenVenta" value="@Model.Id" />

                <div class="col-md-5 position-relative">
                    <label for="productoSearch" class="form-label"><i class="fas fa-box me-1 text-muted"></i>Producto</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                        <input id="productoSearch" class="form-control" placeholder="Buscar producto..." autocomplete="off" />
                    </div>
                    <input type="hidden" name="IdProProducto" id="IdProProducto" />
                    <div id="productoResults" class="list-group autocomplete-dropdown"
                         style="display:none; position:absolute; z-index:1000; width:100%"></div>
                    <span id="productoError" class="text-danger small" style="display:none;"></span>
                </div>

                <div class="col-md-3">
                    <label for="IntPiezasVenta" class="form-label"><i class="fas fa-cubes me-1 text-muted"></i>Piezas</label>
                    <input type="number" name="IntPiezasVenta" id="IntPiezasVenta" class="form-control"
                           min="1" required />
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-success w-100" id="btnAgregarProducto">
                        <i class="fas fa-plus me-1"></i>Agregar Producto
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* ===== Seccion 3: Tabla de VentaDetalle ===== *@
    <div class="card card-table mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-list me-2 text-success"></i>Productos Agregados</span>
            @if (Model.Detalles is not null)
            {
                <span class="badge bg-success">@Model.Detalles.Count productos</span>
            }
        </div>
        <div class="card-body p-0">
            @if (Model.Detalles is null || Model.Detalles.Count == 0)
            {
                <div class="alert alert-info m-3"><i class="fas fa-info-circle me-1"></i>No se han agregado productos a esta venta.</div>
            }
            else
            {
                <div id="skeleton-VentaProductos" class="d-none">
                    <div class="skeleton-table-wrapper">
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                        <div class="skeleton-table-row"><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell"></div><div class="skeleton-cell-actions"></div></div>
                    </div>
                </div>
                <div id="table-VentaProductos">
                    <div class="table-responsive">
                        <table class="table-jtable">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th>Piezas</th>
                                    <th>Total</th>
                                    <th class="text-center" style="width:80px">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detalle in Model.Detalles)
                                {
                                    <tr>
                                        <td>@detalle.StrNombreProducto</td>
                                        <td>@detalle.IntPiezasVenta</td>
                                        <td>@detalle.DecTotalVenta.ToString("C")</td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-eliminar-detalle"
                                                    data-id="@detalle.Id"
                                                    data-rowversion="@Convert.ToBase64String(detalle.RowVersion ?? [])"
                                                    title="Eliminar producto">
                                                <i class="fas fa-trash-can"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="text-end fw-bold fs-5 p-3" id="totalDisplay">
                        <i class="fas fa-dollar-sign me-1 text-success"></i>Total: @Model.Detalles.Sum(d => d.DecTotalVenta).ToString("C")
                    </div>
                    @Html.AntiForgeryToken()
                </div>
            }
        </div>
    </div>

    @* ===== Seccion 4: Boton Guardar ===== *@
    <form method="post" action="/Venta/Guardar" id="guardarForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <input type="hidden" name="rowVersion" id="rowVersionHidden"
               value="@(Model.RowVersion is not null ? Convert.ToBase64String(Model.RowVersion) : "")" />
        <input type="hidden" name="idVenCatEstado" id="idVenCatEstadoHidden" value="@Model.IdVenCatEstado" />

        <div class="d-flex justify-content-end gap-2">
            <a href="/Venta/Index" class="btn btn-outline-secondary"><i class="fas fa-times me-1"></i>Cancelar</a>
            <button type="submit" class="btn btn-success"><i class="fas fa-save me-1"></i>Guardar</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@(ViewContext.HttpContext.Items["ScriptNonce"])">
        (function () {
            var estadoSelect = document.getElementById('idVenCatEstado');
            var estadoHidden = document.getElementById('idVenCatEstadoHidden');
            if (estadoSelect && estadoHidden) {
                estadoSelect.addEventListener('change', function () {
                    estadoHidden.value = estadoSelect.value;
                });
            }

            var productoError = document.getElementById('productoError');

            function setupAutocomplete(searchInputId, hiddenIdInputId, resultsId, url) {
                var searchInput = document.getElementById(searchInputId);
                var hiddenIdInput = document.getElementById(hiddenIdInputId);
                var resultsContainer = document.getElementById(resultsId);
                var selectedId = '';

                if (!searchInput || !hiddenIdInput || !resultsContainer) return;

                searchInput.addEventListener('input', function () {
                    var val = searchInput.value.trim();

                    if (val.length < 2) {
                        resultsContainer.style.display = 'none';
                        resultsContainer.innerHTML = '';
                        if (selectedId !== val) {
                            hiddenIdInput.value = '';
                            selectedId = '';
                            if (productoError) productoError.style.display = 'none';
                        }
                        return;
                    }

                    selectedId = val;
                    hiddenIdInput.value = '';

                    fetch(url + '?texto=' + encodeURIComponent(val))
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            resultsContainer.innerHTML = '';
                            if (!data || data.length === 0) {
                                resultsContainer.style.display = 'none';
                                return;
                            }
                            data.forEach(function (item) {
                                var li = document.createElement('a');
                                li.className = 'list-group-item list-group-item-action';
                                li.href = '#';
                                li.textContent = item.strTextoAutocomplete || '';
                                li.dataset.id = item.id;

                                li.addEventListener('click', function (e) {
                                    e.preventDefault();
                                    hiddenIdInput.value = item.id;
                                    searchInput.value = li.textContent;
                                    resultsContainer.style.display = 'none';
                                    searchInput.classList.add('is-valid');
                                    searchInput.classList.remove('is-invalid');
                                    if (productoError) productoError.style.display = 'none';
                                });
                                resultsContainer.appendChild(li);
                            });
                            resultsContainer.style.display = 'block';
                        })
                        .catch(function (err) {
                            console.error('Autocomplete error:', err);
                            resultsContainer.style.display = 'none';
                        });
                });

                searchInput.addEventListener('blur', function () {
                    setTimeout(function () { resultsContainer.style.display = 'none'; }, 200);
                });

                searchInput.addEventListener('focus', function () {
                    if (resultsContainer.children.length > 0) {
                        resultsContainer.style.display = 'block';
                    }
                });
            }

            setupAutocomplete('productoSearch', 'IdProProducto', 'productoResults', '/Venta/ProductosAutocomplete');

            var agregarForm = document.getElementById('agregarProductoForm');
            if (agregarForm) {
                agregarForm.addEventListener('submit', function (event) {
                    var idPro = document.getElementById('IdProProducto').value;
                    var piezas = document.getElementById('IntPiezasVenta').value;

                    if (!idPro || idPro === '0' || !piezas || parseInt(piezas) < 1) {
                        event.preventDefault();
                        event.stopPropagation();
                        if (productoError) {
                            productoError.textContent = 'Seleccione un producto valido y especifique las piezas.';
                            productoError.style.display = 'block';
                        }
                    }
                });
            }

            var totalDisplay = document.getElementById('totalDisplay');

            document.addEventListener('click', function (e) {
                var btn = e.target.closest('.btn-eliminar-detalle');
                if (!btn) return;

                e.preventDefault();

                if (!confirm('¿Eliminar este producto de la venta?')) return;

                var id = btn.getAttribute('data-id');
                var rowVersion = btn.getAttribute('data-rowversion');

                var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');

                var formData = new FormData();
                formData.append('id', id);
                formData.append('rowVersion', rowVersion);
                if (tokenInput) formData.append('__RequestVerificationToken', tokenInput.value);

                fetch('/Venta/EliminarProducto', {
                    method: 'POST',
                    body: formData
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        var row = btn.closest('tr');
                        var totalText = row.querySelector('td:nth-child(3)').textContent;
                        var totalEliminado = parseFloat(totalText.replace(/[^0-9.-]+/g, '')) || 0;
                        row.remove();

                        if (totalDisplay) {
                            var currentTotalText = totalDisplay.textContent;
                            var currentTotal = parseFloat(currentTotalText.replace(/[^0-9.-]+/g, '')) || 0;
                            var nuevoTotal = currentTotal - totalEliminado;
                            totalDisplay.textContent = 'Total: ' + nuevoTotal.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
                        }

                        if (typeof toastr !== 'undefined') {
                            toastr.success('Producto eliminado correctamente.');
                        }
                    } else {
                        if (typeof toastr !== 'undefined') {
                            toastr.error(data.message || 'Error al eliminar el producto.');
                        } else {
                            alert(data.message || 'Error al eliminar el producto.');
                        }
                    }
                })
                .catch(function (err) {
                    console.error('Error al eliminar detalle:', err);
                    if (typeof toastr !== 'undefined') {
                        toastr.error('Error de conexión al eliminar el producto.');
                    }
                });
            });
        })();
    </script>
}
